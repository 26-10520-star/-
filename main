        /* ==========================================================================
           5. Navigation Controls
           ========================================================================== */
        function changeStep(stepId) {
            currentStep = stepId;
            
            // 모든 스텝 컨테이너 숨기기
            document.querySelectorAll('.step-container').forEach(el => {
                el.classList.add('hidden');
            });

            // 해당 스텝 보이기
            const activeStep = document.getElementById(`step-${stepId}`);
            if (activeStep) {
                activeStep.classList.remove('hidden');
                activeStep.scrollIntoView({ behavior: 'smooth' });
            }

            // 내비게이션 바 하이라이트 제어 (갈색 초록 테마에 맞춰 고정)
            const navs = ['welcome', 'test', 'consult'];
            navs.forEach(n => {
                const navBtn = document.getElementById(`nav-${n}`);
                if (!navBtn) return;
                
                if (n === stepId || (stepId === 'result' && n === 'test') || (stepId === 'prescription' && n === 'consult')) {
                    navBtn.className = "px-4 py-2 rounded text-sm font-medium transition duration-300 bg-korean-brown border border-korean-brownDark text-white";
                } else {
                    navBtn.className = "px-4 py-2 rounded text-sm font-medium transition duration-300 hover:bg-korean-brown hover:text-white text-emerald-100";
                }
            });

            // 스텝 특화 처리
            if (stepId === 'test') {
                initQuiz();
            }
        }

        /* ==========================================================================
           6. Constitution Quiz Algorithm Block
           ========================================================================== */
        function initQuiz() {
            quizAnswers = [];
            currentQuestionIndex = 0;
            renderQuestion();
        }

        function renderQuestion() {
            const currentQ = quizQuestions[currentQuestionIndex];
            
            // 프로그레스 바 및 텍스트 갱신
            document.getElementById('quiz-progress').innerText = `질문 ${currentQuestionIndex + 1} / ${quizQuestions.length}`;
            const percent = ((currentQuestionIndex + 1) / quizQuestions.length) * 100;
            document.getElementById('quiz-bar').style.width = `${percent}%`;

            // 질문 내용
            document.getElementById('question-text').innerText = currentQ.q;

            // 이전 질문 가기 버튼 상태
            const btnPrev = document.getElementById('btn-prev-question');
            if (currentQuestionIndex > 0) {
                btnPrev.classList.remove('hidden');
            } else {
                btnPrev.classList.add('hidden');
            }

            // 질문 항목 렌더링
            const optionsContainer = document.getElementById('quiz-options');
            optionsContainer.innerHTML = '';

            currentQ.options.forEach((opt, idx) => {
                const btn = document.createElement('button');
                btn.className = "w-full text-left p-5 rounded-xl border-2 border-korean-border bg-white hover:border-korean-green hover:bg-korean-greenLight active:bg-stone-200 transition duration-300 flex items-center gap-4 group";
                btn.onclick = () => selectOption(opt.type);

                const numSpan = document.createElement('span');
                numSpan.className = "w-8 h-8 rounded-full border border-stone-300 text-stone-500 font-serif flex items-center justify-center font-bold text-sm bg-[#faf8f4] group-hover:bg-korean-brown group-hover:text-white group-hover:border-korean-brown transition";
                numSpan.innerText = idx + 1;

                const textSpan = document.createElement('span');
                textSpan.className = "text-stone-900 text-sm md:text-base font-serif font-medium flex-grow";
                textSpan.innerText = opt.text;

                btn.appendChild(numSpan);
                btn.appendChild(textSpan);
                optionsContainer.appendChild(btn);
            });
        }

        function selectOption(type) {
            quizAnswers.push(type);
            
            if (currentQuestionIndex < quizQuestions.length - 1) {
                currentQuestionIndex++;
                renderQuestion();
            } else {
                calculateQuizResult();
            }
        }

        function prevQuestion() {
            if (currentQuestionIndex > 0) {
                quizAnswers.pop();
                currentQuestionIndex--;
                renderQuestion();
            }
        }

        function calculateQuizResult() {
            // 체질 점수 산출
            const counts = { 'Taeumin': 0, 'Soeumin': 0, 'Soyangin': 0, 'Taeyangin': 0 };
            quizAnswers.forEach(type => {
                counts[type] = (counts[type] || 0) + 1;
            });

            let maxType = 'Taeumin';
            let maxCount = -1;
            for (const type in counts) {
                if (counts[type] > maxCount) {
                    maxCount = counts[type];
                    maxType = type;
                }
            }

            selectedConstitution = maxType;
            showConstitutionResult();
        }

        function showConstitutionResult() {
            const data = constitutionData[selectedConstitution];
            
            document.getElementById('result-type').innerText = data.name;
            document.getElementById('result-desc').innerText = data.desc;

            // 이로운 약재 바인딩
            const herbList = document.getElementById('result-herbs');
            herbList.innerHTML = '';
            data.herbs.forEach(h => {
                const li = document.createElement('li');
                li.className = "flex gap-3 items-start text-stone-800 text-sm";
                li.innerHTML = `
                    <span class="text-korean-brown mt-0.5"><i class="fa-solid fa-leaf"></i></span>
                    <div>
                        <strong class="font-serif text-stone-900">${h.name}</strong> - <span>${h.desc}</span>
                    </div>
                `;
                herbList.appendChild(li);
            });

            // 생활조언 바인딩
            const adviceList = document.getElementById('result-advice');
            adviceList.innerHTML = '';
            data.advice.forEach(adv => {
                const li = document.createElement('li');
                li.innerText = adv;
                adviceList.appendChild(li);
            });

            changeStep('result');
        }

        function restartQuiz() {
            initQuiz();
            changeStep('test');
        }

        function goToConsultation() {
            changeStep('consult');
        }

        /* ==========================================================================
           7. Prescription & Gemini API Core Integration
           ========================================================================== */
        function selectPresetSymptom(code) {
            selectedSymptomCode = code;
            customSymptomText = '';
            
            // 프리셋 카드 테두리 리셋 및 액티브 처리
            document.querySelectorAll('.symptom-card').forEach(el => {
                el.classList.remove('border-korean-green', 'bg-korean-greenLight');
            });
            
            document.getElementById('custom-symptom-input').value = '';
            buildAndShowPrescription();
        }

        async function submitConsultation() {
            const val = document.getElementById('custom-symptom-input').value.trim();
            if (val.length < 5) {
                if (selectedSymptomCode) {
                    buildAndShowPrescription();
                } else {
                    alert("원하시는 불편함을 카드로 선택하시거나, 상세히 하단 란에 5자 이상 기록하여 조제를 청하십시오.");
                }
                return;
            }

            selectedSymptomCode = 'custom';
            customSymptomText = val;
            await buildAndShowPrescription();
        }

        async function buildAndShowPrescription() {
            changeStep('prescription');
            
            const loadingSec = document.getElementById('prescription-loading');
            const resultSec = document.getElementById('prescription-result');
            
            loadingSec.classList.remove('hidden');
            resultSec.classList.add('hidden');

            const constitName = selectedConstitution ? constitutionData[selectedConstitution].name : "미진단 체질";
            document.getElementById('presc-constit').innerText = constitName;

            if (selectedSymptomCode === 'custom') {
                // 직접 증상을 상세 입력한 경우 AI(Gemini API) 호출
                document.getElementById('presc-symptom').innerText = customSymptomText.substring(0, 15) + (customSymptomText.length > 15 ? '...' : '');
                
                try {
                    await callGeminiForPrescription(constitName, customSymptomText);
                } catch (err) {
                    console.error("실시간 어의 상담에 실패해 향약집성방의 기본 피로 처방으로 대체합니다.", err);
                    loadLocalFallbackPrescription();
                }
            } else {
                // 프리셋 카드를 선택한 경우 로컬 정적 지혜DB에서 불러옴
                const pData = symptomDatabase[selectedSymptomCode];
                document.getElementById('presc-symptom').innerText = pData.name;
                
                document.getElementById('presc-main-herb').innerText = pData.mainHerb;
                document.getElementById('presc-herb-detail').innerText = pData.detail;
                document.getElementById('presc-method').innerText = pData.method;
                document.getElementById('presc-advice').innerText = pData.advice;
            }

            // 가상 대기 모션 연출 후 결과 표출 (고전적 미학 연출)
            setTimeout(() => {
                loadingSec.classList.add('hidden');
                resultSec.classList.remove('hidden');
            }, 800);
        }

        function loadLocalFallbackPrescription() {
            const pData = symptomDatabase['fatigue'];
            document.getElementById('presc-main-herb').innerText = pData.mainHerb;
            document.getElementById('presc-herb-detail').innerText = pData.detail;
            document.getElementById('presc-method').innerText = pData.method;
            document.getElementById('presc-advice').innerText = pData.advice;
        }

        // 실시간 생성형 어의(AI) 연동
        async function callGeminiForPrescription(constitution, symptom) {
            const systemPrompt = `당신은 조선 세종 시대의 어의(왕실 한의학관)입니다. 세종대왕의 명으로 완성된 한의학 백과서 '향약집성방(鄕藥集成方)'을 기반으로 백성들의 병증을 한방적으로 분석하여 자생 토종 약재(향약) 처방과 치료법을 내려 줍니다. 절대 비싸고 구하기 힘든 중국산 수입 당재가 아니라, 우리 강토에서 채취하기 쉽고 효과적인 약초(인삼, 길경, 백출, 모과, 생강, 감국, 복령 등)를 인용하십시오.

아래 JSON 스키마 구조의 유효한 한글 텍스트만을 반드시 출력해야 합니다:
{
  "mainHerb": "대표 자생 약재명 (한글 및 한자 병기)",
  "herbDetail": "해당 약초의 오장 치료 효능 및 우리 강토에서 자라나 해롭지 않음을 친절히 서술 (2~3문장)",
  "rawMethod": "향약집성방의 서체와 치료법을 본딴 고풍스러운 고서 원전 인용문 (하오체)",
  "physicianAdvice": "체질 건강 조절을 위해 일상에서 즉각 실천할 보온, 운동, 심성 관리 조언 (따스한 하오체)"
}`;

            const userQuery = `체질: [${constitution}], 호소 증상: [${symptom}]. 이 기왕에 맞는 실제 향약집성방에 어긋나지 않는 향약 치료 비책을 내려 주옵소서.`;
            const apiKey = ""; // Canvas 런타임 환경에서 자동 처리됨
            const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-3-flash-preview:generateContent?key=${apiKey}`;

            const payload = {
                contents: [{ parts: [{ text: userQuery }] }],
                generationConfig: {
                    responseMimeType: "application/json",
                    responseSchema: {
                        type: "OBJECT",
                        properties: {
                            "mainHerb": { "type": "STRING" },
                            "herbDetail": { "type": "STRING" },
                            "rawMethod": { "type": "STRING" },
                            "physicianAdvice": { "type": "STRING" }
                        },
                        "required": ["mainHerb", "herbDetail", "rawMethod", "physicianAdvice"]
                    }
                },
                systemInstruction: {
                    parts: [{ text: systemPrompt }]
                }
            };

            const response = await fetch(apiUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                throw new Error("Gemini API 통신 실패");
            }

            const result = await response.json();
            const candidateText = result.candidates?.[0]?.content?.parts?.[0]?.text;
            
            if (candidateText) {
                const parsed = JSON.parse(candidateText);
                
                document.getElementById('presc-main-herb').innerText = parsed.mainHerb;
                document.getElementById('presc-herb-detail').innerText = parsed.herbDetail;
                document.getElementById('presc-method').innerText = parsed.rawMethod;
                document.getElementById('presc-advice').innerText = parsed.physicianAdvice;
            } else {
                throw new Error("API 결과 비정상");
            }
        }

        /* ==========================================================================
           8. Print Feature
           ========================================================================== */
        function printPrescription() {
            const modal = document.createElement('div');
            modal.className = "fixed inset-0 bg-black/70 backdrop-blur-sm z-[9999] flex items-center justify-center p-4";
            modal.id = "print-info-modal";
            modal.innerHTML = `
                <div class="bg-[#fcfaf5] p-6 max-w-md w-full rounded-2xl border-4 border-korean-brown text-center font-serif">
                    <span class="text-3xl text-korean-brown"><i class="fa-solid fa-scroll"></i></span>
                    <h4 class="text-xl font-bold mt-3 text-stone-900">향약 처방전 인쇄 • 소장</h4>
                    <p class="text-sm text-stone-700 my-4 leading-relaxed">
                        전시 키오스크에 구비된 프린터를 통해 따뜻한 전통 한지 스타일로 인쇄하시거나, 화면을 촬영하여 관람 기념물로 소중히 간직해 주십시오.
                    </p>
                    <div class="flex gap-3 justify-center">
                        <button onclick="triggerActualPrint()" class="px-5 py-2 bg-korean-green text-white rounded-lg text-sm font-bold hover:bg-korean-greenDark">인쇄하기</button>
                        <button onclick="closePrintModal()" class="px-5 py-2 bg-[#e8e4da] hover:bg-[#dcd7ca] text-stone-750 rounded-lg text-sm">닫기</button>
                    </div>
                </div>
            `;
            document.body.appendChild(modal);
        }

        function closePrintModal() {
            const modal = document.getElementById('print-info-modal');
            if (modal) modal.remove();
        }

        function triggerActualPrint() {
            closePrintModal();
            window.print();
        }
    </script>
</body>
</html>
